# MongoDB Atlas (기존 pc-site와 동일 클러스터 재사용 가능). DB명은 URI 경로 또는 MONGODB_DB로 지정.
MONGODB_URI=
MONGODB_DB=commerce

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# 네이버 쇼핑 검색 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 대시보드(/api/dashboard) 보호용 관리자 키 — 요청 시 Authorization: Bearer <키>
ADMIN_API_KEY=

# 관리자 로그인 비밀번호(미설정 시 ADMIN_API_KEY 사용) / 세션 쿠키 서명 키(미설정 시 ADMIN_API_KEY 사용)
ADMIN_PASSWORD=
SESSION_SECRET=
